# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev:  postgresql://postgres:password@localhost:5432/worldcup2026
# Render/Fly: set via dashboard env var
DATABASE_URL=postgresql://postgres:password@localhost:5432/worldcup2026

# ── football-data.org API ────────────────────────────────────────────────────
# Free tier — 10 req/min. Register at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_api_key_here

# ── API-Football (PRIMARY live-score source) ─────────────────────────────────
# Real-time WC 2026 scores. Free tier = 100 req/day. Get a key at
# https://www.api-football.com/  (dashboard → "API Key").
APIFOOTBALL_KEY=your_apifootball_key_here
# Only set APIFOOTBALL_HOST if you access via RapidAPI instead of direct:
#   APIFOOTBALL_HOST=api-football-v1.p.rapidapi.com

# ── React frontend → backend API ─────────────────────────────────────────────
# The Vite app reads this to find the FastAPI backend (api/main.py).
# Local dev leaves it empty (defaults to http://localhost:8000).
# VITE_API_BASE=https://your-deployed-api.example.com

# ── App Config ───────────────────────────────────────────────────────────────
# Set to "development" or "production"
ENV=development

# Cache TTL in seconds for API responses (5 minutes default)
CACHE_TTL=300
